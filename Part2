2.1 — Table: user_roles (New)
This table enforces the Buyer/Admin vs. Warehouse Staff role separation within a facility account.
CREATE TABLE user_roles (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id         UUID REFERENCES auth.users(id) NOT NULL,
  facility_id     UUID REFERENCES facilities(id) NOT NULL,
  role            TEXT NOT NULL CHECK (role IN ('admin', 'staff')),
  invited_by      UUID REFERENCES auth.users(id),
  invited_at      TIMESTAMPTZ DEFAULT NOW(),
  is_active       BOOLEAN DEFAULT true,
  UNIQUE(user_id, facility_id)  -- one role per facility per user
);

-- RLS: users can only see roles for their own facility
ALTER TABLE user_roles ENABLE ROW LEVEL SECURITY;
CREATE POLICY user_roles_select ON user_roles FOR SELECT
  USING (facility_id IN (
    SELECT facility_id FROM user_roles WHERE user_id = auth.uid()
  ));

-- Only admins can INSERT (invite) new roles
CREATE POLICY user_roles_insert ON user_roles FOR INSERT
  WITH CHECK (
    facility_id IN (
      SELECT facility_id FROM user_roles
      WHERE user_id = auth.uid() AND role = 'admin'
    )
  );
