-- executed by a trigger function owned by the system_lifecycle_worker role).
3.4 — Table: session_events (Strictly Append-Only)
id              UUID PRIMARY KEY DEFAULT gen_random_uuid()
session_id      UUID REFERENCES sessions(id) NOT NULL
event_code      TEXT UNIQUE NOT NULL   -- e.g., 'EVT-001'
