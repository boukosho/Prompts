location_label  TEXT
timestamp_utc   TIMESTAMPTZ DEFAULT NOW()  -- NTP-verified, server-generated
connectivity    TEXT DEFAULT 'ONLINE'
gps_status      TEXT
gps_coordinates JSONB
annotation_text TEXT                   -- for DRIVER_NOTE events only
referenced_event_id UUID REFERENCES session_events(id)
receipt_issued  BOOLEAN DEFAULT false
event_hash      TEXT NOT NULL           -- SHA-256 of this event's payload
prev_event_hash TEXT                    -- hash of prior event (chain link)
raw_payload     JSONB NOT NULL          -- full event data for hash verification

-- ABSOLUTELY NO UPDATE OR DELETE. EVER. Period.
3.5 — Table: evidence_packets
id              UUID PRIMARY KEY DEFAULT gen_random_uuid()
packet_code     TEXT UNIQUE NOT NULL   -- e.g., 'EP-EGW09-S0001'
session_id      UUID REFERENCES sessions(id) NOT NULL
generated_at    TIMESTAMPTZ DEFAULT NOW()
generated_by    UUID REFERENCES auth.users(id)
packet_hash     TEXT NOT NULL           -- SHA-256 of the entire packet
packet_data     JSONB NOT NULL          -- complete snapshot at generation time
verification_url TEXT                   -- public hash verification link
