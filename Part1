3.3 — Table: sessions (Append-Only)
id              UUID PRIMARY KEY DEFAULT gen_random_uuid()
session_code    TEXT UNIQUE NOT NULL  -- e.g., 'S-EGW09-9F2A77C4'
facility_id     UUID REFERENCES facilities(id) NOT NULL
