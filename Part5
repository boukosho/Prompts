  original_created_at TIMESTAMPTZ NOT NULL, -- when the packet was generated
  retention_expired_at TIMESTAMPTZ NOT NULL,-- when content was deleted
  retention_policy_id UUID REFERENCES retention_policies(id) NOT NULL,
  retention_months_at_deletion INTEGER NOT NULL,

  -- Anchoring verification
  anchoring_methods TEXT[] NOT NULL,        -- e.g., ['REGISTRY','THIRD_PARTY']
  registry_digest_id UUID,                  -- ref to hash_registry_digests

  -- Meta
  created_at      TIMESTAMPTZ DEFAULT NOW(),
  tombstone_notice TEXT NOT NULL DEFAULT 
    'Detailed records for this evidence packet have been deleted per retention policy. Only cryptographic proof of prior existence survives. No content reconstruction is possible.'
);

-- Tombstones are WRITE-ONCE, READ-FOREVER
