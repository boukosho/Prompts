2.6 — UPDATE the Session Status Transition Trigger
The update_session_status() trigger from Parts #1/#2 must be extended to handle the new closure paths:
CREATE OR REPLACE FUNCTION update_session_status()
  RETURNS TRIGGER AS $$
BEGIN
  -- CHECK_OUT → normal driver exit
  IF NEW.event_type = 'CHECK_OUT' THEN
    UPDATE sessions SET
      status = 'CLOSED',
      closed_at = NEW.timestamp_utc,
      closure_authority = 'DRIVER_CHECKOUT',
      closure_reason = 'DRIVER_CHECKOUT'
    WHERE id = NEW.session_id AND status = 'OPEN';

  -- MANUAL_CLOSE → facility staff action
  ELSIF NEW.event_type = 'MANUAL_CLOSE' THEN
    UPDATE sessions SET
      status = 'CLOSED',
      closed_at = NEW.timestamp_utc,
      closure_authority = 'FACILITY_USER',
      closure_reason = 'FACILITY_MANUAL_CLOSE'
    WHERE id = NEW.session_id AND status = 'OPEN';

  -- SESSION_TIMEOUT → system enforcement, MAX_DURATION exhausted
  ELSIF NEW.event_type = 'SESSION_TIMEOUT' THEN
    UPDATE sessions SET
      status = 'TIMED_OUT',      -- note: distinct from CLOSED
      closed_at = NEW.timestamp_utc,
      closure_authority = 'SYSTEM_TIMEOUT',
      closure_reason = 'SYSTEM_TIMEOUT_MAX_DURATION'
    WHERE id = NEW.session_id AND status = 'OPEN';

  -- FORCED_CLOSE_ON_OVERLAP → system enforcement, new check-in collision
  ELSIF NEW.event_type = 'FORCED_CLOSE_ON_OVERLAP' THEN
    UPDATE sessions SET
      status = 'TIMED_OUT',
      closed_at = NEW.timestamp_utc,
      closure_authority = 'SYSTEM_TIMEOUT',
      closure_reason = 'FORCED_CLOSE_ON_NEW_CHECKIN'
    WHERE id = NEW.session_id AND status = 'OPEN';

  -- CHECK_IN, PAPERWORK_READY, DRIVER_NOTE, CONTEXT_EVENT, etc.
  -- → DO NOT change session status
  -- (DOCTRINE-013: facility events do not change status)
  END IF;

  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;
