2.4 — Trigger: Populate Projection Table
CREATE OR REPLACE FUNCTION populate_context_event_projection()
  RETURNS TRIGGER AS $$
DECLARE
  v_facility_id UUID;
  v_severity TEXT;
  v_label TEXT;
  v_user_id UUID;
BEGIN
  IF NEW.event_type != 'CONTEXT_EVENT' THEN RETURN NEW; END IF;

  v_label := NEW.raw_payload->>'context_label';
  SELECT severity_tier INTO v_severity
    FROM context_event_taxonomy WHERE label = v_label AND is_active = true;
  IF NOT FOUND THEN
    RAISE EXCEPTION 'Invalid context label: %', v_label;
  END IF;

  SELECT facility_id INTO v_facility_id FROM sessions WHERE id = NEW.session_id;
  v_user_id := (NEW.raw_payload->>'declared_by_user_id')::UUID;

  INSERT INTO session_context_events (
    session_id, event_id, facility_id, context_label, severity_tier,
    declared_by_user, timestamp_utc
  ) VALUES (
    NEW.session_id, NEW.id, v_facility_id, v_label, v_severity,
    v_user_id, NEW.timestamp_utc
  );
  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE TRIGGER trg_populate_context_projection
  AFTER INSERT ON session_events
  FOR EACH ROW WHEN (NEW.event_type = 'CONTEXT_EVENT')
  EXECUTE FUNCTION populate_context_event_projection();
